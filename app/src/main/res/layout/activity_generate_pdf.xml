<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Generate PDF Reports" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="20dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Report Type:" android:textStyle="bold"/>
    <Spinner android:id="@+id/spinnerPdfType" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="15dp"/>

    <EditText android:id="@+id/etPdfSearchQuery" android:layout_width="match_parent" android:layout_height="60dp" android:hint="Enter Customer, Month (MM/YYYY), or Item" android:inputType="text" android:singleLine="true" android:imeOptions="actionDone" android:layout_marginBottom="20dp"/>

    <Button android:id="@+id/btnCreatePdf" android:layout_width="match_parent" android:layout_height="60dp" android:text="Generate &amp; Save PDF" android:backgroundTint="#D32F2F" android:textColor="#FFFFFF"/>

</LinearLayout>